{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "workspace",
      "model": "claude-sonnet-4-6"
    }
  },
  "tools": {
    "allow": [
      "bash",
      "read",
      "write",
      "edit",
      "glob",
      "grep",
      "websearch",
      "webfetch"
    ]
  },
  "session": {
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  }
}